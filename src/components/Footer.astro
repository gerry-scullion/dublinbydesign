---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-top">
    <div class="container">
      <div class="footer-cta">
        <h3>Stay in the loop</h3>
        <p>Follow the conversation about Dublin's evolving urban landscape.</p>
        <a href="/rss.xml" class="md-button md-button--tonal">
          <span class="material-symbols-outlined" aria-hidden="true">rss_feed</span>
          Subscribe via RSS
        </a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <div class="footer-brand">
        <span class="material-symbols-outlined" aria-hidden="true" style="font-size: 20px; color: var(--md-sys-color-inverse-primary)">location_city</span>
        <span>&copy; {year} Dublin by Design</span>
      </div>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="/blog/">Blog</a>
        <a href="/about/">About</a>
        <a href="/rss.xml">RSS</a>
      </nav>
    </div>
  </div>
</footer>
