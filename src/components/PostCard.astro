---
import FormattedDate from './FormattedDate.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  heroImage?: string;
  tags?: string[];
  featured?: boolean;
}

const { title, description, pubDate, slug, heroImage, tags = [], featured = false } = Astro.props;
---

<article class:list={['post-card', { 'post-card--featured': featured }]}>
  <a href={`/blog/${slug}/`}>
    {heroImage ? (
      <div class="post-card-media">
        <img
          class="post-card-image"
          src={heroImage}
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
    ) : (
      <div class="post-card-media post-card-media--empty">
        <span class="material-symbols-outlined" aria-hidden="true">landscape</span>
      </div>
    )}
    <div class="post-card-body">
      <div class="post-card-overline">
        <FormattedDate date={pubDate} />
      </div>
      <h3 class="post-card-title">{title}</h3>
      <p class="post-card-description">{description}</p>
      {tags.length > 0 && (
        <ul class="tag-list" aria-label="Tags">
          {tags.map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )}
    </div>
  </a>
</article>
