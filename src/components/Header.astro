---
const currentPath = Astro.url.pathname;
---

<a class="skip-link" href="#main-content">Skip to content</a>
<header class="site-header" id="site-header">
  <div class="container">
    <a href="/" class="site-title">
      <span class="material-symbols-outlined site-title-icon" aria-hidden="true">location_city</span>
      Dublin by Design
    </a>
    <nav aria-label="Main navigation">
      <ul class="site-nav">
        <li>
          <a href="/" aria-current={currentPath === '/' ? 'page' : undefined}>
            <span class="material-symbols-outlined nav-icon" aria-hidden="true">home</span>
            <span>Home</span>
          </a>
        </li>
        <li>
          <a href="/blog/" aria-current={currentPath.startsWith('/blog') ? 'page' : undefined}>
            <span class="material-symbols-outlined nav-icon" aria-hidden="true">article</span>
            <span>Blog</span>
          </a>
        </li>
        <li>
          <a href="/about/" aria-current={currentPath === '/about/' ? 'page' : undefined}>
            <span class="material-symbols-outlined nav-icon" aria-hidden="true">info</span>
            <span>About</span>
          </a>
        </li>
        <li>
          <a href="/rss.xml" aria-label="RSS Feed">
            <span class="material-symbols-outlined nav-icon" aria-hidden="true">rss_feed</span>
            <span>RSS</span>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          header.classList.toggle('scrolled', window.scrollY > 0);
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }
</script>
